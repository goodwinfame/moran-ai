# ---- PostgreSQL ----
POSTGRES_PASSWORD=moran_dev_password
DATABASE_URL=postgresql://moran:moran_dev_password@localhost:5432/moran

# ---- Server ----
PORT=3200
OPENCODE_PORT=3100
NODE_ENV=development

# ---- LLM API Keys ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ---- WebUI ----
NEXT_PUBLIC_API_URL=http://localhost:3200
