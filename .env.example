# ============================
# 墨染 (MoRan) V2 环境变量模板
# ============================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ---- PostgreSQL ----
POSTGRES_PASSWORD=moran_dev_password
DATABASE_URL=postgresql://moran:moran_dev_password@localhost:5432/moran

# ---- API Server (Hono) ----
PORT=3200
NODE_ENV=development

# ---- Web (Next.js) ----
WEB_PORT=3000
API_UPSTREAM=http://localhost:3200

# ---- OpenCode（由 docker-compose.dev.yml 自动启动，通常无需修改） ----
OPENCODE_BASE_URL=http://127.0.0.1:4096

# ---- Auth ----
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ---- LLM API Keys（至少配置一个） ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
