{
  "name": "@moran/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@moran/agents": "workspace:*",
    "@moran/core": "workspace:*",
    "@opencode-ai/sdk": "^1.4.0",
    "drizzle-orm": "^0.44.7",
    "epub-gen-memory": "^1.1.2",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
