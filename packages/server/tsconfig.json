{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "paths": {
      "@moran/core": ["../core/src"],
      "@moran/core/*": ["../core/src/*"],
      "@moran/agents": ["../agents"],
      "@moran/agents/*": ["../agents/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"],
  "references": [
    { "path": "../core" }
  ]
}
