{
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://host.docker.internal:1234/v1"
      },
      "models": {
        "gemma-4-27b": {
          "context": 120000,
          "output": 8192,
          "tool_call": true,
          "reasoning": true
        }
      }
    }
  },

  "mcp": {
    "moran-mcp": {
      "type": "local",
      "command": ["node", "./packages/mcp-server/dist/index.js"],
      "environment": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    }
  }
}
